# Get credentials at: https://www.discogs.com/settings/developers
DISCOGS_CONSUMER_KEY=your_consumer_key_here
DISCOGS_CONSUMER_SECRET=your_consumer_secret_here

# Simpler alternative to full OAuth — paste your personal token directly
DISCOGS_PERSONAL_TOKEN=your_personal_token_here

FLASK_SECRET_KEY=change-this-to-a-random-string
APP_NAME=DiscogsLister
APP_VERSION=1.0
APP_CONTACT=your@email.com
